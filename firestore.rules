rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function validHandle(handle) {
      return handle is string
        && handle.size() >= 3
        && handle.size() <= 30
        && handle.matches('^[a-z0-9]+(-[a-z0-9]+)*$')
        && !(handle in [
          'acceptable-use', 'api', 'auth', 'cookies', 'dashboard', 'docs',
          'forgot-password', 'legal', 'login', 'onboarding', 'privacy',
          'report', 'security', 'self-host', 'settings', 'sign-in', 'sign-up',
          'sponsor', 'support', 'terms'
        ]);
    }

    function validGitHubUsername(username) {
      return username is string
        && username.size() >= 1
        && username.size() <= 39
        && username.matches('^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$')
        && !username.matches('.*--.*');
    }

    function validActivityTitle(title) {
      return title is string
        && title.size() >= 1
        && title.size() <= 60
        && title.matches('.*[^[:space:]].*');
    }

    function validRepositoryName(name) {
      return name is string
        && name.size() >= 1
        && name.size() <= 140;
    }

    function validRepositoryNames(names) {
      return names is list
        && names.size() <= 5
        && (names.size() < 1 || validRepositoryName(names[0]))
        && (names.size() < 2 || validRepositoryName(names[1]))
        && (names.size() < 3 || validRepositoryName(names[2]))
        && (names.size() < 4 || validRepositoryName(names[3]))
        && (names.size() < 5 || validRepositoryName(names[4]));
    }

    function validRepositorySelection(repositories) {
      return repositories is map
        && repositories.keys().hasOnly(['mode', 'names'])
        && repositories.keys().hasAll(['mode', 'names'])
        && repositories.mode is string
        && repositories.mode in ['recent', 'include', 'exclude']
        && validRepositoryNames(repositories.names);
    }

    function validCommitActivity(commits) {
      return commits is map
        && commits.keys().hasOnly([
          'enabled', 'title', 'limit', 'showRepository', 'showDate'
        ])
        && commits.keys().hasAll([
          'enabled', 'title', 'limit', 'showRepository', 'showDate'
        ])
        && commits.enabled is bool
        && validActivityTitle(commits.title)
        && commits.limit is int
        && commits.limit >= 1
        && commits.limit <= 10
        && commits.showRepository is bool
        && commits.showDate is bool;
    }

    function validCodingActivity(coding) {
      return coding is map
        && coding.keys().hasOnly([
          'enabled', 'title', 'windowDays', 'showContributionCount',
          'showHeatmap', 'showMonthLabels', 'showWeekdayLabels',
          'showLegend', 'showYearSelector', 'showLanguages'
        ])
        && coding.keys().hasAll([
          'enabled', 'title', 'windowDays', 'showContributionCount',
          'showHeatmap', 'showMonthLabels', 'showWeekdayLabels',
          'showLegend', 'showYearSelector', 'showLanguages'
        ])
        && coding.enabled is bool
        && validActivityTitle(coding.title)
        && coding.windowDays is int
        && coding.windowDays in [7, 14, 30]
        && coding.showContributionCount is bool
        && coding.showHeatmap is bool
        && coding.showMonthLabels is bool
        && coding.showWeekdayLabels is bool
        && coding.showLegend is bool
        && coding.showYearSelector is bool
        && coding.showLanguages is bool;
    }

    function validDeveloperActivity(activity) {
      return activity is map
        && activity.keys().hasOnly([
          'enabled', 'githubUsername', 'placement', 'repositories', 'commits', 'coding'
        ])
        && activity.keys().hasAll([
          'enabled', 'githubUsername', 'placement', 'repositories', 'commits', 'coding'
        ])
        && activity.enabled is bool
        && activity.githubUsername is string
        && activity.githubUsername.size() <= 39
        && (activity.githubUsername == ''
          || validGitHubUsername(activity.githubUsername))
        && (!activity.enabled || validGitHubUsername(activity.githubUsername))
        && activity.placement is string
        && activity.placement in ['before-links', 'after-links']
        && validRepositorySelection(activity.repositories)
        && validCommitActivity(activity.commits)
        && validCodingActivity(activity.coding)
        && (!activity.enabled
          || (!activity.commits.enabled && !activity.coding.enabled)
          || activity.repositories.mode != 'include'
          || activity.repositories.names.size() > 0);
    }

    function validProfile(uid) {
      return request.resource.data.keys().hasOnly([
          'ownerUid', 'handle', 'displayName', 'role', 'bio', 'avatarUrl',
          'ogImageUrl', 'location', 'availability', 'theme', 'accent', 'published',
          'socials', 'sections', 'links', 'developerActivity', 'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'ownerUid', 'handle', 'displayName', 'role', 'bio', 'theme',
          'accent', 'published', 'socials', 'links', 'updatedAt'
        ])
        && request.resource.data.ownerUid == uid
        && validHandle(request.resource.data.handle)
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 1
        && request.resource.data.displayName.size() <= 60
        && request.resource.data.role is string
        && request.resource.data.role.size() <= 100
        && request.resource.data.bio is string
        && request.resource.data.bio.size() <= 240
        && (!('avatarUrl' in request.resource.data)
          || (request.resource.data.avatarUrl is string
            && request.resource.data.avatarUrl.size() <= 2048))
        && (!('ogImageUrl' in request.resource.data)
          || (request.resource.data.ogImageUrl is string
            && request.resource.data.ogImageUrl.size() <= 2048
            && request.resource.data.ogImageUrl.matches('^https://.*')))
        && (!('location' in request.resource.data)
          || (request.resource.data.location is string
            && request.resource.data.location.size() <= 80))
        && (!('availability' in request.resource.data)
          || (request.resource.data.availability is string
            && request.resource.data.availability.size() <= 90))
        && request.resource.data.theme in ['terminal', 'paper', 'midnight', 'mono']
        && request.resource.data.accent is string
        && request.resource.data.accent.matches('^#[0-9a-fA-F]{6}$')
        && request.resource.data.published is bool
        && request.resource.data.socials is map
        && request.resource.data.socials.keys().hasOnly([
          'github', 'gitlab', 'linkedin', 'x', 'youtube', 'instagram', 'tiktok',
          'facebook', 'threads', 'bluesky', 'mastodon', 'discord', 'twitch',
          'reddit', 'medium', 'hashnode', 'devto', 'stackoverflow', 'codepen',
          'codesandbox', 'dribbble', 'behance', 'figma', 'npm', 'producthunt',
          'telegram', 'whatsapp', 'spotify', 'soundcloud', 'apple_music',
          'patreon', 'kofi', 'buymeacoffee', 'calendly', 'calcom', 'email',
          'website'
        ])
        && (!('sections' in request.resource.data)
          || (request.resource.data.sections is list
            && request.resource.data.sections.size() <= 12))
        && (!('developerActivity' in request.resource.data)
          || validDeveloperActivity(request.resource.data.developerActivity))
        && request.resource.data.links is list
        && request.resource.data.links.size() <= 50
        && request.resource.data.updatedAt == request.time;
    }

    match /users/{uid} {
      allow read, create, update, delete: if owns(uid);
    }

    match /profiles/{uid} {
      allow read: if resource.data.published == true || owns(uid);
      allow create, update: if owns(uid) && validProfile(uid);
      allow delete: if owns(uid);
    }

    match /handles/{handle} {
      allow read: if true;
      allow create: if signedIn()
        && validHandle(handle)
        && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && validHandle(handle);
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /reports/{reportId} {
      allow create: if request.resource.data.keys().hasOnly([
          'handle', 'reason', 'details', 'contactEmail', 'createdAt', 'status'
        ])
        && request.resource.data.handle is string
        && request.resource.data.handle.size() <= 64
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 100
        && request.resource.data.details is string
        && request.resource.data.details.size() >= 20
        && request.resource.data.details.size() <= 1000
        && (request.resource.data.contactEmail == null
          || (request.resource.data.contactEmail is string
            && request.resource.data.contactEmail.size() <= 254))
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if false;
    }

    function validStatsPayload() {
      return request.resource.data.keys().hasOnly([
          'handle', 'totalClicks', 'links', 'socials', 'updatedAt'
        ])
        && validHandle(request.resource.data.handle)
        && request.resource.data.totalClicks is int
        && request.resource.data.totalClicks >= 0
        && request.resource.data.links is map
        && request.resource.data.socials is map
        && request.resource.data.updatedAt == request.time;
    }

    match /profileStats/{uid} {
      allow read: if owns(uid);
      allow create: if validStatsPayload()
        && request.resource.data.totalClicks == 1;
      allow update: if validStatsPayload()
        && request.resource.data.totalClicks == resource.data.totalClicks + 1
        && request.resource.data.links.keys().size() >= resource.data.links.keys().size()
        && request.resource.data.socials.keys().size() >= resource.data.socials.keys().size();
      allow delete: if owns(uid);
    }

    function validContributionCache(usernameKey) {
      return request.resource.data.keys().hasOnly([
          'username', 'days', 'availableYears', 'updatedAt', 'version', 'source', 'syncedYears'
        ])
        && request.resource.data.username is string
        && request.resource.data.username == usernameKey
        && validGitHubUsername(request.resource.data.username)
        && request.resource.data.days is map
        && request.resource.data.days.keys().size() <= 5500
        && request.resource.data.availableYears is list
        && request.resource.data.availableYears.size() <= 15
        && request.resource.data.syncedYears is list
        && request.resource.data.syncedYears.size() <= 15
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.version is int
        && request.resource.data.version >= 1
        && request.resource.data.source in ['profile', 'github', 'events'];
    }

    // Public GitHub contribution day map. Past days are reused so GitHub is
    // only queried for the current day (and for initial/full year fills).
    match /githubContributionCaches/{usernameKey} {
      allow read: if true;
      allow create, update: if validContributionCache(usernameKey);
      allow delete: if false;
    }

    function validLanguageCache(usernameKey) {
      return request.resource.data.keys().hasOnly([
          'username', 'byYear', 'syncedYears', 'updatedAt', 'version'
        ])
        && request.resource.data.username is string
        && request.resource.data.username == usernameKey
        && validGitHubUsername(request.resource.data.username)
        && request.resource.data.byYear is map
        && request.resource.data.byYear.keys().size() <= 15
        && request.resource.data.syncedYears is list
        && request.resource.data.syncedYears.size() <= 15
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.version is int
        && request.resource.data.version >= 1;
    }

    // Year-scoped language mixes for public GitHub activity.
    match /githubLanguageCaches/{usernameKey} {
      allow read: if true;
      allow create, update: if validLanguageCache(usernameKey);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
