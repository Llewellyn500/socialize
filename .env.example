# Public site URL used for canonical and social metadata.
# Production canonical host.
NEXT_PUBLIC_SITE_URL=https://www.socialize.you

# Backend web app configuration (your project dashboard → Project settings → Your apps).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional locally; required for production browser reports and click analytics,
# and before enforcing Firebase App Check for Firestore or Storage. Use a
# Firebase App Check reCAPTCHA Enterprise site key.
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=

# Google Analytics 4 measurement ID. The existing NEXT_PUBLIC_MEASURING_ID
# variable is also supported for backwards compatibility.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: YouTube Data API key for richer channel metadata on link autofill.
# Without it, Socialize falls back to public oEmbed / Open Graph data.
YOUTUBE_API_KEY=

# Optional server-only GitHub token. Enables the full contribution calendar
# (same graph as github.com, including anonymized private counts when the
# user shares them on their profile). Must NOT grant private repository
# contents — use classic `read:user` only, or fine-grained Profile read with
# no repo access. Never use NEXT_PUBLIC_.
GITHUB_TOKEN=

# Required for the hosted production deployment's trusted server writes:
# click aggregation, abuse reports, and GitHub activity caches. Paste the
# complete Firebase service-account JSON as one server-only environment value.
# Never commit it and never prefix it with NEXT_PUBLIC_.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Server-only production assertions. Set these to true only after verifying
# legitimate App Check traffic/enforcement and applying Vercel WAF rate limits
# to public /api routes in the Vercel dashboard, API, or Terraform.
FIREBASE_APP_CHECK_ENFORCED=false
VERCEL_FIREWALL_CONFIGURED=false

# Required public legal-operator settings for production.
NEXT_PUBLIC_LEGAL_OPERATOR_NAME=
NEXT_PUBLIC_LEGAL_OPERATOR_ADDRESS=
NEXT_PUBLIC_LEGAL_GOVERNING_LAW=
NEXT_PUBLIC_LEGAL_VENUE=
NEXT_PUBLIC_LEGAL_LIABILITY_CAP=
NEXT_PUBLIC_LEGAL_EFFECTIVE_DATE=

# Required public, deliverable contact addresses for production. `npm run
# prod:check` verifies that every configured domain publishes an MX record.
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_SECURITY_EMAIL=
NEXT_PUBLIC_PRIVACY_EMAIL=
NEXT_PUBLIC_SAFETY_EMAIL=
NEXT_PUBLIC_LEGAL_EMAIL=
NEXT_PUBLIC_SPONSORS_EMAIL=

# Optional: set after adding a GitHub Sponsors profile.
NEXT_PUBLIC_GITHUB_SPONSOR_URL=https://github.com/sponsors/Llewellyn500
