# Public site URL used for canonical and social metadata.
# Production: https://socialize.you
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend web app configuration (your project dashboard → Project settings → Your apps).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Analytics 4 measurement ID. The existing NEXT_PUBLIC_MEASURING_ID
# variable is also supported for backwards compatibility.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: YouTube Data API key for richer channel metadata on link autofill.
# Without it, Socialize falls back to public oEmbed / Open Graph data.
YOUTUBE_API_KEY=

# Optional: GitHub token for higher API rate limits on link autofill.
GITHUB_TOKEN=

# Optional: set after adding a GitHub Sponsors profile.
NEXT_PUBLIC_GITHUB_SPONSOR_URL=https://github.com/sponsors/Llewellyn500
