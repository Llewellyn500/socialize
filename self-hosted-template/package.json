{
  "name": "socialize-self-hosted",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:production": "npm run validate:env:production && next build",
    "build:vercel": "npm run validate:env && next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "validate:env": "node --env-file-if-exists=.env.local scripts/validate-production-env.mjs self-hosted",
    "validate:env:production": "node --env-file-if-exists=.env.local scripts/validate-production-env.mjs self-hosted --production",
    "validate:env:runtime": "node --env-file-if-exists=.env.local scripts/validate-production-env.mjs self-hosted --production --runtime",
    "prod:check": "node --env-file-if-exists=.env.local scripts/validate-production-env.mjs self-hosted --production --vercel"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "firebase": "^12.16.0",
    "next": "15.5.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "0.35.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.16",
    "sharp": "0.35.0"
  }
}
