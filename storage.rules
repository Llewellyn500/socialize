rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsPath(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidAvatar() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif)');
    }

    function isValidOgImage() {
      return request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType == 'image/png';
    }

    function isValidProfileMedia() {
      return request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif|svg\\+xml)');
    }

    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow create, update: if ownsPath(uid) && isValidAvatar();
      allow delete: if ownsPath(uid);
    }

    match /og/{uid}/{fileName} {
      allow read: if true;
      allow create, update: if ownsPath(uid) && isValidOgImage();
      allow delete: if ownsPath(uid);
    }

    match /profile-media/{uid}/{scope}/{itemId}/{fileName} {
      allow read: if true;
      allow create, update: if ownsPath(uid)
        && scope in ['links', 'sections']
        && fileName == 'media'
        && isValidProfileMedia();
      allow delete: if ownsPath(uid);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
